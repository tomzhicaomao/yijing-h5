        {
          "position": 3,
          "yao_ci": "鼎耳革，其行塞，雉膏不食，方雨虧悔，終吉"
        },
        {
          "position": 4,
          "yao_ci": "鼎折足，覆公餗，其形渥，凶"
        },
        {
          "position": 5,
          "yao_ci": "鼎黃耳金鉉，利貞"
        },
        {
          "position": 6,
          "yao_ci": "鼎玉鉉，大吉，无不利"
        }
      ]
    },
    {
      "id": 51,
      "name": "震",
      "gua_ci": "亨，震來虩虩，笑言啞啞，震驚百里，不喪匕鬯",
      "yao": [
        {
          "position": 1,
          "yao_ci": "震來虩虩，後笑言啞啞，吉"
        },
        {
          "position": 2,
          "yao_ci": "震來厲，億喪貝，躋于九陵，勿逐，七日得"
        },
        {
          "position": 3,
          "yao_ci": "震蘇蘇，震行无眚"
        },
        {
          "position": 4,
          "yao_ci": "震遂泥"
        },
        {
          "position": 5,
          "yao_ci": "震往來厲，億无喪有事"
        },
        {
          "position": 6,
          "yao_ci": "震索索，視矍矍，征凶，震不于其躬，于其鄰，无咎，婚媾有言"
        }
      ]
    },
    {
      "id": 52,
      "name": "艮",
      "gua_ci": "艮其背，不獲其身，行其庭，不見其人，无咎",
      "yao": [
        {
          "position": 1,
          "yao_ci": "艮其趾，无咎，利永貞"
        },
        {
          "position": 2,
          "yao_ci": "艮其腓，不拯其隨，其心不快"
        },
        {
          "position": 3,
          "yao_ci": "艮其限，列其夤，厲薰心"
        },
        {
          "position": 4,
          "yao_ci": "艮其身，无咎"
        },
        {
          "position": 5,
          "yao_ci": "艮其輔，言有序，悔亡"
        },
        {
          "position": 6,
          "yao_ci": "敦艮，吉"
        }
      ]
    },
    {
      "id": 53,
      "name": "漸",
      "gua_ci": "女歸吉，利貞",
      "yao": [
        {
          "position": 1,
          "yao_ci": "鴻漸于干，小子厲，有言，无咎"
        },
        {
          "position": 2,
          "yao_ci": "鴻漸于磐，飲食衎衎，吉"
        },
        {
          "position": 3,
          "yao_ci": "鴻漸于陸，夫征不復，婦孕不育，凶"
        },
        {
          "position": 4,
          "yao_ci": "鴻漸于木，或得其桷，无咎"
        },
        {
          "position": 5,
          "yao_ci": "鴻漸于陵，婦三歲不孕，終莫之勝，吉"
        },
        {
          "position": 6,
          "yao_ci": "鴻漸于陸，其羽可用為儀，吉"
        }
      ]
    },
    {
      "id": 54,
      "name": "歸妹",
      "gua_ci": "征凶，无攸利",
      "yao": [
        {
          "position": 1,
          "yao_ci": "歸妹以娣，跛能履，征吉"
        },
        {
          "position": 2,
          "yao_ci": "眇能視，利幽人之貞"
        },
        {
          "position": 3,
          "yao_ci": "歸妹以須，反歸以娣"
        },
        {
          "position": 4,
          "yao_ci": "歸妹愆期，遲歸有時"
        },
        {
          "position": 5,
          "yao_ci": "帝乙歸妹，其君之袂不如其娣之袂良，月幾望，吉"
        },
        {
          "position": 6,
          "yao_ci": "女承筐无實，士刲羊无血，无攸利"
        }
      ]
    },
    {
      "id": 55,
      "name": "豐",
      "gua_ci": "亨，王假之，勿憂，宜日中",
      "yao": [
        {
          "position": 1,
          "yao_ci": "遇其配主，雖旬无咎，往有尚"
        },
        {
          "position": 2,
          "yao_ci": "豐其蔀，日中見斗，往得疑疾，有孚發若，吉"
        },
        {
          "position": 3,
          "yao_ci": "豐其沛，日中見沫，折其右肱，无咎"
        },
        {
          "position": 4,
          "yao_ci": "豐其蔀，日中見斗，遇其夷主，吉"
        },
        {
          "position": 5,
          "yao_ci": "來章，有慶譽，吉"
        },
        {
          "position": 6,
          "yao_ci": "豐其屋，蔀其家，窺其戶，闃其无人，三歲不覿，凶"
        }
      ]
    },
    {
      "id": 56,
      "name": "旅",
      "gua_ci": "小亨，旅貞吉",
      "yao": [
        {
          "position": 1,
          "yao_ci": "旅瑣瑣，斯其所取災"
        },
        {
          "position": 2,
          "yao_ci": "旅即次，懷其資，得童僕貞"
        },
        {
          "position": 3,
          "yao_ci": "旅焚其次，喪其童僕，貞厲"
        },
        {
          "position": 4,
          "yao_ci": "旅于處，得其資斧，我心不快"
        },
        {
          "position": 5,
          "yao_ci": "射雉一矢亡，終以譽命"
        },
        {
          "position": 6,
          "yao_ci": "鳥焚其巢，旅人先笑後號咷，喪牛于易，凶"
        }
      ]
    },
    {
      "id": 57,
      "name": "巽",
      "gua_ci": "小亨，利有攸往，利見大人",
      "yao": [
        {
          "position": 1,
          "yao_ci": "進退，利武人之貞"
        },
        {
          "position": 2,
          "yao_ci": "巽在床下，用史巫紛若，吉无咎"
        },
        {
          "position": 3,
          "yao_ci": "頻巽，吝"
        },
        {
          "position": 4,
          "yao_ci": "悔亡，田獲三品"
        },
        {
          "position": 5,
          "yao_ci": "貞吉悔亡，无不利，无初有終"
        },
        {
          "position": 6,
          "yao_ci": "巽在床下，喪其資斧，貞凶"
        }
      ]
    },
    {
      "id": 58,
      "name": "兌",
      "gua_ci": "亨，利貞",
      "yao": [
        {
          "position": 1,
          "yao_ci": "和兌，吉"
        },
        {
          "position": 2,
          "yao_ci": "孚兌，吉，悔亡"
        },
        {
          "position": 3,
          "yao_ci": "來兌，凶"
        },
        {
          "position": 4,
          "yao_ci": "商兌未寧，介疾有喜"
        },
        {
          "position": 5,
          "yao_ci": "孚于剝，有厲"
        },
        {
          "position": 6,
          "yao_ci": "引兌"
        }
      ]
    },
    {
      "id": 59,
      "name": "渙",
      "gua_ci": "亨，王假有廟，利涉大川，利貞",
      "yao": [
        {
          "position": 1,
          "yao_ci": "用拯馬壯，吉"
        },
        {
          "position": 2,
          "yao_ci": "渙奔其机，悔亡"
        },
        {
          "position": 3,
          "yao_ci": "渙其躬，无悔"
        },
        {
          "position": 4,
          "yao_ci": "渙其群，元吉，渙有丘，匪夷所思"
        },
        {
          "position": 5,
          "yao_ci": "渙汗其大號，渙王居，无咎"
        },
        {
          "position": 6,
          "yao_ci": "渙其血去逖出，无咎"
        }
      ]
    },
    {
      "id": 60,
      "name": "節",
      "gua_ci": "亨，苦節不可貞",
      "yao": [
        {
          "position": 1,
          "yao_ci": "不出戶庭，无咎"
        },
        {
          "position": 2,
          "yao_ci": "不出門庭，凶"
        },
        {
          "position": 3,
          "yao_ci": "不節若，則嗟若，无咎"
        },
        {
          "position": 4,
          "yao_ci": "安節，亨"
        },
        {
          "position": 5,
          "yao_ci": "甘節，吉，往有尚"
        },
        {
          "position": 6,
          "yao_ci": "苦節，貞凶，悔亡"
        }
      ]
    },
    {
      "id": 61,
      "name": "中孚",
      "gua_ci": "豚魚吉，利涉大川，利貞",
      "yao": [
        {
          "position": 1,
          "yao_ci": "虞吉，有他不燕"
        },
        {
          "position": 2,
          "yao_ci": "鳴鶴在陰，其子和之，我有好爵，吾與爾靡之"
        },
        {
          "position": 3,
          "yao_ci": "得敵，或鼓或罷，或泣或歌"
        },
        {
          "position": 4,
          "yao_ci": "月幾望，馬匹亡，无咎"
        },
        {
          "position": 5,
          "yao_ci": "有孚攣如，无咎"
        },
        {
          "position": 6,
          "yao_ci": "翰音登于天，貞凶"
        }
      ]
    },
    {
      "id": 62,
      "name": "小過",
      "gua_ci": "亨利貞，可小事，不可大事，飛鳥遺之音，不宜上宜下，大吉",
      "yao": [
        {
          "position": 1,
          "yao_ci": "飛鳥以凶"
        },
        {
          "position": 2,
          "yao_ci": "過其祖，遇其妣，不及其君，遇其臣，无咎"
        },
        {
          "position": 3,
          "yao_ci": "弗過防之，從或戕之，凶"
        },
        {
          "position": 4,
          "yao_ci": "无咎，弗過遇之，往厲必戒，勿用永貞"
        },
        {
          "position": 5,
          "yao_ci": "密雲不雨，自我西郊，公弋取彼在穴"
        },
        {
          "position": 6,
          "yao_ci": "弗遇過之，飛鳥離之，凶，是謂災眚"
        }
      ]
    },
    {
      "id": 63,
      "name": "既濟",
      "gua_ci": "亨小利貞，初吉終亂",
      "yao": [
        {
          "position": 1,
          "yao_ci": "曳其輪，濡其尾，无咎"
        },
        {
          "position": 2,
          "yao_ci": "婦喪其茀，勿逐，七日得"
        },
        {
          "position": 3,
          "yao_ci": "高宗伐鬼方，三年克之，小人勿用"
        },
        {
          "position": 4,
          "yao_ci": "繻有衣袽，終日戒"
        },
        {
          "position": 5,
          "yao_ci": "東鄰殺牛，不如西鄰之禴祭，實受其福"
        },
        {
          "position": 6,
          "yao_ci": "濡其首，厲"
        }
      ]
    },
    {
      "id": 64,
      "name": "未濟",
      "gua_ci": "亨，小狐汔濟，濡其尾，无攸利",
      "yao": [
        {
          "position": 1,
          "yao_ci": "濡其尾，吝"
        },
        {
          "position": 2,
          "yao_ci": "曳其輪，貞吉"
        },
        {
          "position": 3,
          "yao_ci": "未濟，征凶，利涉大川"
        },
        {
          "position": 4,
          "yao_ci": "貞吉悔亡，震用伐鬼方，三年有賞于大國"
        },
        {
          "position": 5,
          "yao_ci": "貞吉无悔，君子之光，有孚吉"
        },
        {
          "position": 6,
          "yao_ci": "有孚于饮酒，无咎，濡其首，有孚失是"
        }
      ]
    }
  ]
}